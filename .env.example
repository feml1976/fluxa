# ============================================================
# FLUXA — Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores reales en .env
#   3. NUNCA commitees .env al repositorio
#   4. .env está en .gitignore — verificar antes de cada commit
# ============================================================

# ── Entorno ──────────────────────────────────────────────────
APP_ENV=local
APP_NAME=FLUXA
APP_VERSION=1.0.0

# ── PostgreSQL (Docker) ──────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fluxa_db
POSTGRES_USER=fluxa_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Spring Boot — JDBC URL ───────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fluxa_db
SPRING_DATASOURCE_USERNAME=fluxa_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ──────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_A_SECURE_64_BYTE_BASE64_SECRET
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000        # 15 minutos
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000    # 7 días

# ── Email (SMTP) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_EMAIL@gmail.com
MAIL_PASSWORD=CHANGE_ME_APP_PASSWORD
MAIL_FROM_NAME=FLUXA Finanzas
MAIL_FROM_ADDRESS=CHANGE_ME_EMAIL@gmail.com

# ── pgAdmin (Solo desarrollo local con Docker) ───────────────
PGADMIN_EMAIL=admin@fluxa.local
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
PGADMIN_PORT=5050

# ── Spring Boot — Configuración General ──────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# ── Frontend (Vite) ──────────────────────────────────────────
# Archivo: frontend/.env.local
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_NAME=FLUXA
VITE_APP_VERSION=1.0.0
